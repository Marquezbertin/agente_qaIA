# ============================================================
# QA Agent - Configuracao de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com seus valores:
#   cp .env.example .env
# ============================================================

# ============================================================
# PROVEDORES DE IA (pelo menos um obrigatorio)
# ============================================================

# Anthropic Claude (recomendado - suporte completo a Tool Use)
ANTHROPIC_API_KEY=cole-sua-chave-aqui
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI GPT (experimental - suporte parcial a Tool Use)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Gemini (experimental - suporte basico)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Provedor padrao (anthropic, openai, gemini)
AI_PROVIDER=anthropic

# ============================================================
# INTEGRACAO GIT (GitHub/GitLab)
# ============================================================
# Token de acesso pessoal (GitHub: fine-grained token, GitLab: personal access token)
GIT_TOKEN=
# Repositorio no formato: usuario/repo (ex: Marquezbertin/agente_qaIA)
GIT_REPO=
# Provedor: github ou gitlab
GIT_PROVIDER=github
# URL do GitLab (apenas para self-hosted)
GITLAB_URL=https://gitlab.com/api/v4

# ============================================================
# PROJETO DE TESTES
# ============================================================

# Diretorio do projeto de testes (opcional)
# Se nao definido, usa sample_project/ incluso no agente
# TEST_PROJECT_DIR=C:\caminho\para\seu\projeto\de\testes

# ============================================================
# STREAMLIT - AUTENTICACAO (opcional)
# ============================================================
# Ativar autenticacao basica (true/false)
STREAMLIT_AUTH=false
# Credenciais (usuario:senha separado por :)
STREAMLIT_USERS=admin:admin123

# ============================================================
# DEMAIS CONFIGURACOES
# ============================================================

# Timeout para chamadas de API em segundos (opcional)
API_TIMEOUT=120

# Maximo de retentativas em caso de falha (opcional)
MAX_RETRIES=3

# Nivel de log (opcional)
# Opcoes: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
